{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET client-window Launch (console)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build client-window.csproj",
      "program": "${workspaceFolder}/client-window/bin/Debug/net10.0/client-window.dll",
      "args": [
        "localhost:9055",
        "tcp",
        "test",
        "pass"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": ".NET server Launch (console)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build server.csproj",
      "program": "${workspaceFolder}/server/bin/Debug/net10.0/server.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    }
  ]
}