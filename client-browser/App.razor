@using System.Collections.Concurrent
@using System.IO
@using System.Net
@using System.Text
@using System.Threading
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using operation_vote.Client
@using operation_vote.Shared
@using SocketRequestHandler = Client.Request.SocketRequestHandlerWS

@implements IDisposable
@inject NavigationManager navigationManager
@inject IJSRuntime JsRuntime

@if (!_isOperational)
{
  <div class="connection-overlay">
    <form class="connection-card" id="login-form">
      <h2>Connect to Voting Server</h2>
      <p>Specify the target infrastructure address below:</p>

      <div class="form-group">
        <input type="text" @bind="ServerUri" class="input-field" placeholder="ws://127.0.0.1:9056/"
               @onkeypress="HandleConnectKeyPairSubmit" @oninput="UpdateInputField" disabled="@_isConnecting" />
        @if (navigationManager.BaseUri.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
          <small>Connecting to ws://(instead of wss://) servers in this https:// page may fail and silently crash the
            app.</small>
          }
          <div class="form-group" style="display: @(UseAnonymous ? "none" : "flex");" @ref="LoginFields">
            <div>
              <input type="text" @ref="UsernameField" @oninput="e => {Username = (string?)e.Value ?? string.Empty;UpdateInputField();}" value="@Username" class="input-field"
                    placeholder="Username" disabled="@_isConnecting" />
              <input type="text" class="hidden-field" autocomplete="username" @ref="BrowserStorageField"
                      @oninput="e => BrowserStorageUsername = (string?)e.Value ?? string.Empty" tabindex="-1" />
            </div>
            <div class="form-item">
              <input type="@(HidePassword ? "password" : "text")" @ref="PasswordField" @bind="Password" class="input-field"
                     placeholder="Password" disabled="@_isConnecting" autocomplete="new-password"
                     @onfocus='()=>JsRuntime.InvokeVoidAsync("window.helpers.updateInputField", BrowserStorageField, string.Empty)' />
              <input type="checkbox" @bind="@HidePassword" class="checkbox-field" id="hide-password"
                     disabled="@_isConnecting" />
              <label for="hide-password">Hide</label>
            </div>
          </div>
          <div class="form-item">
            <input type="checkbox" @bind="@UseAnonymous" class="checkbox-field" id="use-anonymous"
                   disabled="@_isConnecting" />
            <label for="use-anonymous">Anonymous</label>
          </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
          <div class="error-banner">
            @_errorMessage
          </div>
        }

        @if (_isConnecting)
        {
          <div class="loading-steps-box">
            <div class="step-row">
              <span class="step-dot @(CurrentStep >= 1 ? "done" : "active")"></span>
              <span class="step-text">Allocating network handle tasks...</span>
            </div>
            <div class="step-row">
              <span class="step-dot @(CurrentStep >= 2 ? "done" : CurrentStep == 1 ? "active" : "")"></span>
              <span class="step-text">Executing remote WebSocket handshake...</span>
            </div>
            <div class="step-row">
              <span class="step-dot @(CurrentStep >= 3 ? "done" : CurrentStep == 2 ? "active" : "")"></span>
              <span class="step-text">Parsing structural operation metrics...</span>
            </div>
            <div class="step-row">
              <span class="step-dot @(CurrentStep == 4 ? "active" : "")"></span>
              <span class="step-text">Handing off viewport keyboard traps...</span>
            </div>

            <div class="mini-progress-track">
              <div class="mini-progress-bar" style="width: @(CurrentStep * 25)%"></div>
            </div>
          </div>
        }
        else
        {
          <button class="connect-btn" type="submit" @onclick="ConnectToServerAsync" @onsubmit:preventDefault="true">
            <span>Establish Link</span>
          </button>
        }
      </form>
    </div>
  }
else
  {
    <div class="voting-container" @onkeydown="OHandleKeyDown" @onkeyup="OHandleKeyUp" @onmousedown="OHandleMouseDown"
         @onmouseup="OHandleMouseUp" @ontouchstart="OHandleTouchStart" @ontouchend="OHandleTouchEnd"
         @ontouchstart:preventDefault="true" @ontouchend:preventDefault="true" @oncontextmenu:preventDefault="true"
         tabindex="0" @ref="containerRef"
         style="touch-action: none; user-select: none; -webkit-user-select: none; outline: none; width: 100%; height: 100vh;">

      <div class="status-card @StatusClass">
        <h1>@StatusTitle</h1>
        <p class="status-subtitle">@StatusMessage</p>
        <div class="disconnect-action-zone">
          <button class="disconnect-btn" @onclick="ManualDisconnect">Terminate Session</button>
        </div>
      </div>
    </div>
  }

@code {
  private static readonly string InstructionsProtocolVersion = "1.2";
  private ElementReference containerRef;
  private CancellationTokenSource? _cts;
  private SocketRequestHandler? _wsHandler;
  private VotingClient<SocketRequestHandler>? _client;

  // Upgraded to concurrent structures to support thread-safe background lookup operations
  private readonly ConcurrentDictionary<string, OperationData> _keyOpMapping = new();
  private readonly ConcurrentDictionary<string, byte> _pressedInputState = new();

  private long _lastClickTicks = DateTime.UtcNow.Ticks;
  private SortedList<TimeSpan, OperationData>? _timeouts = null;
  private readonly SemaphoreSlim _afkSignal = new(0, 1);
  private readonly ReaderWriterLockSlim _afkLock = new();
  private Task? _afkLoopTask;
  private CancellationTokenSource? _afkCts;

  private bool _isOperational = false;
  private bool _isConnecting = false;
  private bool _touched = false;
  private string _errorMessage = "";
  private int CurrentStep { get; set; } = 0;

  private string ServerUri { get; set; } = "ws://192.168.1.2:9056/";
  private string Username { get; set; } = "";
  private string Password { get; set; } = "";
  private ElementReference UsernameField;
  private ElementReference PasswordField;
  private ElementReference BrowserStorageField;
  private ElementReference LoginFields;
  private bool UseAnonymous { get; set; } = true;
  private bool HidePassword { get; set; } = true;
  private string StatusTitle { get; set; } = "Initializing System";
  private string StatusMessage = "Synchronizing operational maps...";
  private string StatusClass = "ready";
  private string BrowserStorageUsername
  {
    get => $"{Username.Length}:{Username}@{ServerUri}";
    set
    {
      if (string.IsNullOrEmpty(value)) return;
      int colonIndex = value.IndexOf(':');
      if (colonIndex <= 0) return;
      ReadOnlySpan<char> valueSpan = value.AsSpan();
      if (!int.TryParse(valueSpan.Slice(0, colonIndex), out int usernameLength) || usernameLength < 0) return;
      int expectedAtMarkerIndex = colonIndex + 1 + usernameLength;
      if (value.Length <= expectedAtMarkerIndex) return;
      if (value[expectedAtMarkerIndex] != '@') return;
      Username = value.Substring(colonIndex + 1, usernameLength);
      ServerUri = value.Substring(expectedAtMarkerIndex + 1);
    }
  }

  private async Task ConnectToServerAsync()
  {
    if (string.IsNullOrWhiteSpace(ServerUri))
    {
      _errorMessage = "Target URI address field cannot be empty.";
      return;
    }

    _isConnecting = true;
    _errorMessage = "";
    CurrentStep = 1;
    StateHasChanged();

    string? actualFailureDetail = null;
    try
    {
      _cts = new CancellationTokenSource();
      _wsHandler = new SocketRequestHandler();
      _client = new VotingClient<SocketRequestHandler>(_wsHandler, ServerUri, _cts.Token)
      {
        authenticationData = UseAnonymous ? null : new(Username, Password)
      };

      _client.OnDisconnect += HandleClientDisconnect;
      TaskCompletionSource<string?> authCs = new();

      _client.OnAuthorizationFinished += (object? sender, bool success) =>
      {
        if (!success)
        {
          var client = (VotingClient<SocketRequestHandler>?)sender;
          var username = client?.authenticationData?.Username;
          var message = username == null ? "Failed to authorize to the operation server." : $"Failed to authorize to the operation server as {username}.";
          authCs.SetResult(message);
        }
        else
        {
          authCs.SetResult(null);
        }
      }; // strict login requirement

      CurrentStep = 2;
      StateHasChanged();

      await _client.ConnectAsync();
      authCs.TrySetResult(null);
      var authRes = await authCs.Task;
      if (authRes != null)
      {
        _client?.Dispose();
        actualFailureDetail = authRes;
        throw new Exception();
      }

      CurrentStep = 3;
      StateHasChanged();

      int checkIntervals = 0;
      while ((_client.OperationTypes == null || _client.OperationTypes.Count == 0) && checkIntervals < 60)
      {
        await Task.Delay(50, _cts.Token);
        checkIntervals++;
      }

      try
      {
        ParseServerOperationalProfiles(out var parsedTimeouts);

        _afkLock.EnterWriteLock();
        try
        {
          _timeouts = parsedTimeouts;
        }
        finally
        {
          _afkLock.ExitWriteLock();
        }

        // Reset and trigger background loop synchronization activity
        Interlocked.Exchange(ref _lastClickTicks, DateTime.UtcNow.Ticks);
        _afkSignal.Release();
      }
      catch (Exception parseEx)
      {
        Console.WriteLine($"[Bypass Warning] Operational data profile mapping skipped: {parseEx.Message}");
      }

      CurrentStep = 4;
      StateHasChanged();

      StatusTitle = "System Operational";
      StatusMessage = "PC: Click Left/Right/Middle or press keys. Phone: Tap/Hold screen.";
      StatusClass = "ready";
      _isOperational = true;
      StateHasChanged();

      _ = Task.Delay(100).ContinueWith(async _ =>
      {
        try { await containerRef.FocusAsync(); } catch { /* no-op */ }
      });
    }
    catch (Exception ex)
    {
      actualFailureDetail ??= ex.Message;
      if (ex is ObjectDisposedException || actualFailureDetail.Contains("SemaphoreSlim") ||
actualFailureDetail.Contains("ObjectDisposed"))
      {
        if (ex.InnerException != null)
        {
          actualFailureDetail = ex.InnerException.Message;
        }
        else if (_wsHandler != null && !_wsHandler.IsConnected)
        {
          actualFailureDetail = "Remote server rejected or dropped connection immediately following successful handshake.";
        }
        else
        {
          actualFailureDetail = "Handshake synchronization timeout. No operational parameters received from host node.";
        }
      }

      _errorMessage = $"Handshake failure: {actualFailureDetail}";
      _isConnecting = false;
      CurrentStep = 0;
      StateHasChanged();

      await Task.Delay(200);
      DisconnectAndReset();
    }
    finally
    {
      _isConnecting = false;
      CurrentStep = 0;
      StateHasChanged();
    }
  }

  private void HandleClientDisconnect(object? sender, (SocketRequestHandler Handler, string Reason) data)
  {
    _afkLock.EnterWriteLock();
    try
    {
      _timeouts = null;
    }
    finally
    {
      _afkLock.ExitWriteLock();
    }

    try { _afkSignal.Release(); } catch { /* no-op */ }

    InvokeAsync(() =>
    {
      _errorMessage = $"Server disconnected connection: {data.Reason}";
      DisconnectAndReset();
      StateHasChanged();
    });
  }

  private void ManualDisconnect()
  {
    _errorMessage = "Session manually terminated by user.";
    DisconnectAndReset();
  }

  private void DisconnectAndReset()
  {
    _isOperational = false;
    _pressedInputState.Clear();
    _keyOpMapping.Clear();

    if (_client != null)
    {
      _client.OnDisconnect -= HandleClientDisconnect;
    }

    try { _cts?.Cancel(); } catch { /* no-op */ }

    var clientToDispose = _client;
    var handlerToDispose = _wsHandler;
    var ctsToDispose = _cts;

    _client = null;
    _wsHandler = null;
    _cts = null;

    try { clientToDispose?.Dispose(); } catch { /* no-op */ }
    try { handlerToDispose?.Dispose(); } catch { /* no-op */ }
    try { ctsToDispose?.Dispose(); } catch { /* no-op */ }
  }

  private async Task HandleConnectKeyPairSubmit(KeyboardEventArgs e)
  {
    if (e.Key == "Enter" && !_isConnecting)
    {
      await ConnectToServerAsync();
    }
  }

  private void ParseServerOperationalProfiles(out SortedList<TimeSpan, OperationData> afkList)
  {
    afkList = [];
    if (_client == null || _client.OperationTypes == null) return;

    var availableOpTypes = _client.OperationTypes.Values.ToList();
    foreach (var opType in availableOpTypes)
    {
      if (opType?.Instructions == null || opType.Instructions.Length == 0) continue;

      var instructionsStrings = new List<string>();
      using var ms = new MemoryStream(opType.Instructions);
      using var reader = new BinaryReader(ms, Encoding.UTF8);
      TimeSpan? afk = null;

      try
      {
        var header = reader.ReadString();
        if (header != $"V{InstructionsProtocolVersion}") throw new ProtocolViolationException("Instructions protocol is mismatched.");

        while (ms.Position < ms.Length)
        {
          var instructionType = reader.ReadString();
          switch (instructionType)
          {
            case "keys:":
              var keysLength = reader.Read7BitEncodedInt64();
              for (int i = 0; i < keysLength; ++i)
              {
                instructionsStrings.Add(reader.ReadString());
              }
              break;
            case "afk:":
              afk = TimeSpan.FromMilliseconds(reader.ReadDouble());
              break;
          }
        }
      }
      catch
      {
        continue;
      }

      OperationData result = new(opType, afk);
      foreach (string key in instructionsStrings)
      {
        if (!string.IsNullOrEmpty(key))
          _keyOpMapping[key] = result;
      }
      if (afk != null)
      {
        afkList[afk.Value] = result;
      }
    }
  }

  private async Task HandleKeyDown(KeyboardEventArgs e) => await ProcessInputDownAsync(e.Key);
  private async Task HandleKeyUp(KeyboardEventArgs e) => await ProcessInputUpAsync(e.Key);

  private async Task HandleMouseDown(MouseEventArgs e)
  {
    if (_touched) return;
    string? mouseKey = ConvertButtonToKey(e.Button);
    if (mouseKey != null) await ProcessInputDownAsync(mouseKey);
  }

  private async Task HandleMouseUp(MouseEventArgs e)
  {
    if (_touched)
    {
      _touched = false;
      return;
    }
    string? mouseKey = ConvertButtonToKey(e.Button);
    if (mouseKey != null) await ProcessInputUpAsync(mouseKey);
  }

  private async Task HandleTouchStart(TouchEventArgs e)
  {
    _touched = true;
    await ProcessInputDownAsync("MouseLeft");
  }

  private Task HandleTouchEnd(TouchEventArgs e) => ProcessInputUpAsync("MouseLeft");

  private async Task ProcessInputDownAsync(string inputKey)
  {
    if (_client == null || !_isOperational) return;
    HandleUserOperation();

    if (_keyOpMapping.TryGetValue(inputKey, out var targetedOpData))
    {
      if (_pressedInputState.TryAdd(inputKey, 0))
      {
        StatusTitle = "Action Active";
        StatusMessage = $"Holding: '{inputKey}'";
        StatusClass = "active";

        using var supportOp = new Operation(targetedOpData.Type, VoteType.Support, Array.Empty<byte>());
        await _client.SendOperationAsync(supportOp, default);
      }
    }
  }

  private async Task ProcessInputUpAsync(string inputKey)
  {
    if (_client == null || !_isOperational) return;
    HandleUserOperation();

    if (_keyOpMapping.TryGetValue(inputKey, out var targetedOpData))
    {
      if (_pressedInputState.TryRemove(inputKey, out _))
      {
        StatusTitle = "Action Released";
        StatusMessage = $"Released: '{inputKey}'";
        StatusClass = "ready";

        using var releaseOp = new Operation(targetedOpData.Type, VoteType.Against, Array.Empty<byte>());
        await _client.SendOperationAsync(releaseOp, default);
      }
    }
  }

  private string? ConvertButtonToKey(long buttonId) => buttonId switch
  {
    0 => "MouseLeft",
    1 => "MouseMiddle",
    2 => "MouseRight",
    _ => null
  };

  private void HandleUserOperation()
  {
    Interlocked.Exchange(ref _lastClickTicks, DateTime.UtcNow.Ticks);
    try { _afkSignal.Release(); } catch { /* no-op */ }
  }

  private async Task AFKProcessingThreadAsync(CancellationToken token)
  {
    while (!token.IsCancellationRequested)
    {
      SortedList<TimeSpan, OperationData>? localTimeouts;
      long clickTicks;

      _afkLock.EnterReadLock();
      try
      {
        localTimeouts = _timeouts;
        clickTicks = Volatile.Read(ref _lastClickTicks);
      }
      finally
      {
        _afkLock.ExitReadLock();
      }

      if (localTimeouts == null)
      {
        try { await _afkSignal.WaitAsync(token); } catch (OperationCanceledException) { break; }
        continue;
      }

      DateTime lastClickTime = new DateTime(Volatile.Read(ref clickTicks), DateTimeKind.Utc);
      TimeSpan lowestWait = TimeSpan.MaxValue;
      bool executePulse = false;
      OperationData? targetedOp = null;

      foreach (var item in localTimeouts)
      {
        TimeSpan calculatedDeadline = item.Key;
        TimeSpan elapsed = DateTime.UtcNow - lastClickTime;
        TimeSpan remainingWait = calculatedDeadline - elapsed;

        if (remainingWait <= TimeSpan.Zero)
        {
          executePulse = true;
          targetedOp = item.Value;
          break;
        }
        else if (remainingWait < lowestWait)
        {
          lowestWait = remainingWait;
        }
      }

      if (executePulse && targetedOp != null)
      {
        var activeClient = _client;
        if (activeClient != null && _isOperational)
        {
          try
          {
            using var afkOp = new Operation(targetedOp.Type, VoteType.Abstain, Array.Empty<byte>());
            await activeClient.SendOperationAsync(afkOp, token);
          }
          catch { /* Handle drop errors contextually */ }
        }

        // Sleep for a short cool-down period before tracking the next timing window match
        try { await Task.Delay(1000, token); } catch (OperationCanceledException) { break; }
      }
      else
      {
        int waitMilliseconds = lowestWait == TimeSpan.MaxValue ? -1 : (int)lowestWait.TotalMilliseconds;
        try
        {
          await _afkSignal.WaitAsync(waitMilliseconds, token);
        }
        catch (OperationCanceledException)
        {
          break;
        }
      }
    }
  }

  protected override void OnInitialized()
  {
    _afkCts = new CancellationTokenSource();
    _afkLoopTask = AFKProcessingThreadAsync(_afkCts.Token);
  }

  public void Dispose()
  {
    try { _afkCts?.Cancel(); } catch { /* no-op */ }
    try { _afkCts?.Dispose(); } catch { /* no-op */ }
    try { _afkSignal?.Dispose(); } catch { /* no-op */ }
    try { _afkLock?.Dispose(); } catch { /* no-op */ }

    DisconnectAndReset();
  }

  public async Task EventWrapper(Task result)
  {
    try
    {
      await result;
    }
    catch (Exception e)
    {
      _errorMessage = e.Message;
      try
      {
        _client?.Dispose();
      }
      finally { }
      ;
    }
  }
  public Task OHandleInputPassword(TouchEventArgs e) => EventWrapper(HandleTouchEnd(e));
  public Task OHandleKeyDown(KeyboardEventArgs e) => EventWrapper(HandleKeyDown(e));
  public Task OHandleKeyUp(KeyboardEventArgs e) => EventWrapper(HandleKeyUp(e));
  public Task OHandleMouseDown(MouseEventArgs e) => EventWrapper(HandleMouseDown(e));
  public Task OHandleMouseUp(MouseEventArgs e) => EventWrapper(HandleMouseUp(e));
  public Task OHandleTouchStart(TouchEventArgs e) => EventWrapper(HandleTouchStart(e));
  public Task OHandleTouchEnd(TouchEventArgs e) => EventWrapper(HandleTouchEnd(e));
  private Task UpdateInputField() =>
    JsRuntime.InvokeVoidAsync("window.helpers.updateInputField", BrowserStorageField, BrowserStorageUsername).AsTask();
}